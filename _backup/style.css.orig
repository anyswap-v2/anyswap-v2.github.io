:root {
  --bg: #F6F4F1;
  --bg-soft: #EEEAE4;
  --surface: #FFFFFF;
  --surface-soft: #F9F8F6;
  --ink: #101214;
  --text: #30343A;
  --muted: #6D737C;
  --faint: #A3A7AD;
  --line: rgba(16, 18, 20, 0.10);
  --line-strong: rgba(16, 18, 20, 0.16);
  --accent: #26C6A6;
  --accent-soft: rgba(38, 198, 166, 0.13);
  --shadow: 0 28px 80px rgba(16, 18, 20, 0.14);
  --shadow-soft: 0 14px 36px rgba(16, 18, 20, 0.08);
}

* {
  box-sizing: border-box;
}

html,
body {
  min-height: 100%;
}

body {
  min-height: 100dvh;
  margin: 0;
  overflow: hidden;
  color: var(--ink);
  background:
    radial-gradient(circle at 50% -14%, var(--accent-soft), transparent 38%),
    linear-gradient(180deg, var(--bg), var(--bg-soft));
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  display: flex;
  flex-direction: column;
}

a {
  color: inherit;
  text-decoration: none;
}

img {
  display: block;
  max-width: 100%;
}

.topbar {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 18px;
  padding: 18px clamp(18px, 4vw, 44px);
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
  color: var(--ink);
  font-size: 1rem;
  font-weight: 750;
  letter-spacing: 0;
}

.brand img {
  width: 30px;
  height: 30px;
  border-radius: 9px;
  box-shadow: 0 0 0 1px var(--line);
  flex: 0 0 auto;
}

.nav {
  display: flex;
  align-items: center;
  gap: clamp(16px, 2.5vw, 28px);
  margin-left: 8px;
}

.nav a {
  color: var(--muted);
  font-size: 0.92rem;
  font-weight: 550;
  transition: color 160ms ease;
}

.nav a:hover {
  color: var(--ink);
}

.spacer {
  flex: 1 1 auto;
}

.ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40px;
  padding: 0 18px;
  border: 1px solid var(--line-strong);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.58);
  color: var(--text);
  font-size: 0.91rem;
  font-weight: 700;
  box-shadow: var(--shadow-soft);
  transition: border-color 160ms ease, color 160ms ease, transform 160ms ease;
}

.ghost:hover {
  border-color: var(--accent);
  color: var(--ink);
  transform: translateY(-1px);
}

.stage {
  flex: 1 1 auto;
  width: min(100%, 1040px);
  margin: 0 auto;
  padding: clamp(14px, 3vh, 28px) clamp(18px, 4vw, 44px) 10px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.hero {
  width: min(100%, 720px);
}

h1 {
  margin: 0;
  color: var(--ink);
  font-size: clamp(3.15rem, 7vw, 5.35rem);
  line-height: 0.98;
  font-weight: 820;
  letter-spacing: 0;
}

.value {
  margin: 18px auto 0;
  max-width: 56ch;
  color: var(--muted);
  font-size: clamp(1rem, 1.5vw, 1.18rem);
}

.value strong {
  color: var(--ink);
  font-weight: 760;
}

.app-card {
  width: min(100%, 610px);
  margin-top: clamp(28px, 5vh, 44px);
  padding: 18px;
  border: 1px solid var(--line);
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: var(--shadow);
}

.route {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 48px minmax(0, 1fr);
  align-items: center;
  gap: 12px;
}

.leg {
  min-width: 0;
  padding: 15px 16px;
  border: 1px solid var(--line);
  border-radius: 16px;
  background: var(--surface-soft);
  text-align: left;
}

.label {
  display: block;
  color: var(--faint);
  font-size: 0.72rem;
  font-weight: 760;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.asset {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
  margin-top: 9px;
  color: var(--ink);
  font-size: 1.12rem;
  font-weight: 800;
}

.asset img {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  box-shadow: 0 0 0 1px var(--line);
  flex: 0 0 auto;
}

.switch {
  width: 48px;
  height: 48px;
  border: 1px solid var(--line-strong);
  border-radius: 50%;
  background: var(--surface);
  color: var(--ink);
  display: grid;
  place-items: center;
  cursor: pointer;
  box-shadow: var(--shadow-soft);
  transition: border-color 160ms ease, color 160ms ease, transform 180ms ease;
}

.switch span {
  display: block;
  font-size: 1.2rem;
  line-height: 1;
}

.switch:hover {
  border-color: var(--accent);
  color: var(--accent);
  transform: translateY(-1px);
}

.switch.is-swapped span {
  transform: rotate(180deg);
}

.primary {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 56px;
  width: 100%;
  margin-top: 16px;
  border-radius: 16px;
  background: var(--accent);
  color: #FFFFFF;
  font-size: 1.02rem;
  font-weight: 820;
  box-shadow: 0 18px 38px rgba(38, 198, 166, 0.24);
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 22px 46px rgba(38, 198, 166, 0.30);
}

.footer {
  flex: 0 0 auto;
  padding: 18px 24px 24px;
  color: var(--muted);
  font-size: 0.85rem;
  font-weight: 600;
  text-align: center;
}

@media (max-width: 700px) {
  body {
    overflow-x: hidden;
    overflow-y: hidden;
  }

  .topbar {
    gap: 12px;
    padding: 15px 16px 8px;
  }

  .brand {
    font-size: 0.96rem;
  }

  .nav {
    display: none;
  }

  .ghost {
    min-height: 38px;
    padding-inline: 14px;
    font-size: 0.88rem;
    box-shadow: none;
  }

  .stage {
    padding: 10px 16px 4px;
  }

  h1 {
    font-size: clamp(2.68rem, 13vw, 3.24rem);
  }

  .value {
    margin-top: 14px;
    font-size: 0.98rem;
    line-height: 1.46;
  }

  .app-card {
    margin-top: 24px;
    padding: 14px;
    border-radius: 20px;
  }

  .route {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .leg {
    padding: 13px 14px;
  }

  .switch {
    justify-self: center;
    width: 42px;
    height: 42px;
  }

  .switch span {
    transform: rotate(90deg);
  }

  .switch.is-swapped span {
    transform: rotate(270deg);
  }

  .primary {
    min-height: 52px;
    margin-top: 14px;
  }

  .footer {
    padding: 8px 18px 16px;
  }
}

@media (max-height: 700px) {
  .topbar {
    padding-top: 12px;
    padding-bottom: 8px;
  }

  .stage {
    padding-top: 6px;
  }

  .value {
    margin-top: 12px;
  }

  .app-card {
    margin-top: 18px;
  }

  .footer {
    padding-top: 8px;
    padding-bottom: 12px;
  }
}
